# Copy this file to `.env` in the same folder (FRONTEND/) and fill in real values.
# Never commit `.env` — it is listed in `.gitignore`.
#
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or newer publishable key (sb_publishable_...) — both work with createClient
VITE_SUPABASE_ANON_KEY=sb_publishable_...OR_eyJhbGciOiJIUzI1NiIs...
