# Copy this file to `.env` in the same folder (FRONTEND/) and fill in real values.
# Never commit `.env` — it is listed in `.gitignore`.
#
# If you see "Cannot reach Supabase": open https://supabase.com/dashboard → your project
# → Project Settings → API, and paste the exact Project URL and anon (public) key below.
# Use the same project for both lines; a typo or wrong project often causes fetch failures.
# The frontend accepts either the Vite-style names below or the legacy repo names
# `SUPABASE_URL` / `SUPABASE_ANON_KEY`.
# After editing `.env`, restart the dev server (Vite reads env at startup).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or newer publishable key (sb_publishable_...) — both work with createClient
VITE_SUPABASE_ANON_KEY=sb_publishable_...OR_eyJhbGciOiJIUzI1NiIs...
# Copy to `.env` in this folder (never commit real keys).
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# Dashboard live stocks + news + symbol search use Finnhub if set, otherwise Alpha Vantage (either key is enough).
VITE_ALPHA_VANTAGE_API_KEY=

# Google AI (Gemini): https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Chat (POST /api/chat): local `npm run dev` runs the handler inside Vite — no BACKEND. Same vars work on Vercel (serverless, not VITE_*).
# GROQ_API_KEY=gsk_...
# Optional: GROQ_MODEL=llama-3.3-70b-versatile
# Or use Gemini: GEMINI_API_KEY= / GOOGLE_AI_API_KEY= , optional GEMINI_CHAT_MODEL=
# Optional: LLM_PROVIDER=auto|groq|gemini
# Profile-aware chat also needs (non-VITE is fine — merged into process.env for the API route):
# SUPABASE_URL=   (or rely on VITE_SUPABASE_URL)
# SUPABASE_ANON_KEY=
# Optional delayed quotes in chat: ALPHA_VANTAGE_KEY=
#
# Optional legacy separate API for Yahoo proxy only:
# VITE_BACKEND_URL=https://your-api.example.com

# Optional: Finnhub (quotes, news, search). If set, it is preferred over Alpha Vantage for those features.
# On Vercel, add either name — both are supported after build:
#   VITE_FINNHUB_API_KEY=...   (recommended; Vite default)
#   FINNHUB_API_KEY=...        (also works; exposed via envPrefix in vite.config)
# After changing env vars on Vercel, redeploy — Vite bakes them in at build time.
# VITE_FINNHUB_API_KEY=

# Optional: on-chain achievement NFTs — auto local setup:
#   cd blockchain && npm install && npm run badge:auto-local
# (starts Hardhat on :8545, deploys, merges these into FRONTEND/.env — restart Vite after.)
# VITE_BADGE_NFT_CONTRACT_ADDRESS=0x...
# VITE_NFT_RPC_URL=http://127.0.0.1:8545
