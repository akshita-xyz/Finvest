# Copy this file to `.env` in the same folder (FRONTEND/) and fill in real values.
# Never commit `.env` — it is listed in `.gitignore`.
#
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or newer publishable key (sb_publishable_...) — both work with createClient
VITE_SUPABASE_ANON_KEY=sb_publishable_...OR_eyJhbGciOiJIUzI1NiIs...
# Copy to `.env` in this folder (never commit real keys).
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_API_KEY=

# Google AI (Gemini): https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional: FINVEST BACKEND base URL (e.g. http://localhost:3001) so the dashboard can load Yahoo chart JSON
# in production when Finnhub /stock/candle is not available on your plan.
# VITE_BACKEND_URL=http://localhost:3001

# Optional: Finnhub API key (same as dashboard quotes). Used as a fallback for the risk candlestick chart when
# Yahoo data cannot be proxied (e.g. static hosting). Requires a Finnhub tier that allows /stock/candle.
# VITE_FINNHUB_API_KEY=
