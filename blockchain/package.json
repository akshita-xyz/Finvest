{
  "name": "finvest-blockchain",
  "private": true,
  "version": "1.0.0",
  "description": "Finvest achievement NFT (ERC-721) — from code/swagat branch, extended for production mint control",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js",
    "node:chain": "hardhat node",
